{
  "kind": "collectionType",
  "collectionName": "article_blogs",
  "info": {
    "singularName": "article-blog",
    "pluralName": "article-blogs",
    "displayName": "ArticleBlog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "titre_article": {
      "type": "string",
      "required": true
    },
    "resume": {
      "type": "text"
    },
    "corps_article": {
      "type": "richtext"
    },
    "image_couverture": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "date_publication": {
      "type": "datetime",
      "required": true
    },
    "auteurs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::auteur.auteur",
      "mappedBy": "article_blog"
    }
  }
}
