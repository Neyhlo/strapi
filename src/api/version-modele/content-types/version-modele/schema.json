{
  "kind": "collectionType",
  "collectionName": "version_modeles",
  "info": {
    "singularName": "version-modele",
    "pluralName": "version-modeles",
    "displayName": "VersionModèle"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "identifiant_version": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "date_publication": {
      "type": "datetime",
      "required": true
    },
    "fichier_modele": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "taille_fichier": {
      "type": "integer"
    },
    "note_version": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::note-version.note-version",
      "mappedBy": "version_modele"
    },
    "guide_demarrages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::guide-demarrage.guide-demarrage",
      "mappedBy": "version_modele"
    },
    "contenu_libres": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::contenu-libre.contenu-libre",
      "mappedBy": "version_modele"
    }
  }
}
